# Qwen ASR Server Configuration

# Model settings
MODEL_ID=Qwen/Qwen3-ASR-1.7B
QUANT_MODE=4bit
DTYPE=bfloat16

# Optional: Load Qwen3-ForcedAligner for word-level timestamps and SRT output.
# Leave empty to disable (saves VRAM and startup time).
# FORCED_ALIGNER_ID=Qwen/Qwen3-ForcedAligner-0.6B

# GPU settings
CUDA_VISIBLE_DEVICES=1
GPU_MEMORY_UTILIZATION=0.8
MAX_MODEL_LEN=32768

# Ampere GPU optimizations (A100 / A10 / A30 / RTX 3x/4x series)
# Keep CUDA graph capture enabled — reduces per-request latency on Ampere.
# Set to true only for debugging or on very-low-VRAM cards.
ENFORCE_EAGER=false
# Limit allocator block splits to reduce GPU memory fragmentation.
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512

# Audio limits
MAX_AUDIO_SECONDS=1200

# Server settings
HOST=0.0.0.0
PORT=8000
